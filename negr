<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>С ДР, КЕНТ! 🎂</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            overflow: hidden;
            background: #020205;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100% !important;
            height: 100% !important;
            display: block;
        }
    </style>
</head>
<body>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/EffectComposer.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/RenderPass.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/ShaderPass.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/CopyShader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/shaders/LuminosityHighPassShader.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/postprocessing/UnrealBloomPass.js"></script>

<script>
    let scene, camera, renderer, composer;
    let particlesGroup;
    let startTime = Date.now();
    
    const PARTICLE_COUNT = 3000; 
    const TEXT_STRING = "С др, negr";

    let state = {
        phase: 'assemble_cake', // assemble_cake -> explode_candles
        timeInPhase: 0
    };

    // Математика генерации 3D праздничного торта с ярусами
    function getCakePoint(index, total, scale) {
        // Делим частицы: 85% на торт, 15% на свечи сверху
        const isCandle = index > total * 0.85;
        
        if (!isCandle) {
            // Строим 3 яруса торта цилиндрической формы
            let tier = 0;
            if (index < total * 0.4) tier = 1;       // Нижний большой ярус
            else if (index < total * 0.7) tier = 2;  // Средний ярус
            else tier = 3;                           // Верхний маленький ярус

            let radius = 0, heightMin = 0, heightMax = 0;
            if (tier === 1) { radius = 140; heightMin = -120; heightMax = -40; }
            else if (tier === 2) { radius = 95; heightMin = -40; heightMax = 30; }
            else { radius = 55; heightMin = 30; heightMax = 90; }

            const theta = Math.random() * Math.PI * 2;
            // Делаем ярусы заполненными по бокам
            const r = radius * (0.85 + Math.random() * 0.15); 
            const x = r * Math.cos(theta) * scale;
            const z = r * Math.sin(theta) * scale;
            const y = (heightMin + Math.random() * (heightMax - heightMin)) * scale;

            return { pos: new THREE.Vector3(x, y, z), type: 'cake' };
        } else {
            // Ставим несколько вертикальных свечек на верхний ярус
            const candleIndex = index % 5; // 5 свечей
            const angle = (candleIndex / 5) * Math.PI * 2;
            const candleRadius = 30; 
            
            const baseX = candleRadius * Math.cos(angle);
            const baseZ = candleRadius * Math.sin(angle);
            // Свечки идут вверх от верхушки торта
            const x = (baseX + (Math.random() - 0.5) * 4) * scale;
            const z = (baseZ + (Math.random() - 0.5) * 4) * scale;
            const y = (100 + Math.random() * 50) * scale;

            return { pos: new THREE.Vector3(x, y, z), type: 'candle', id: candleIndex };
        }
    }

    function createTextTexture(text) {
        const canvas = document.createElement('canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = 256;
        canvas.height = 64;
        ctx.fillStyle = 'rgba(0,0,0,0)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        ctx.font = 'Bold 38px monospace';
        ctx.fillStyle = '#ffffff';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(text, canvas.width / 2, canvas.height / 2);
        
        return new THREE.CanvasTexture(canvas);
    }

    function init() {
        scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0x020205, 0.0015);

        camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 2000);
        camera.position.set(0, 100, 600); // Камера чуть приподнята, чтобы видеть торт в 3D объеме

        renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);

        const renderScene = new THREE.RenderPass(scene, camera);
        const bloomPass = new THREE.UnrealBloomPass(new THREE.Vector2(window.innerWidth, window.innerHeight), 1.6, 0.4, 0.85);
        bloomPass.threshold = 0.0;
        bloomPass.strength = 2.2; // Мощный неоновый свет
        bloomPass.radius = 0.6;

        composer = new THREE.EffectComposer(renderer);
        composer.addPass(renderScene);
        composer.addPass(bloomPass);

        particlesGroup = new THREE.Group();
        scene.add(particlesGroup);

        const texture = createTextTexture(TEXT_STRING);
        
        const isMobile = window.innerWidth < 768;
        // Коэффициент подстройки под размеры экрана мобилки
        const currentScale = isMobile ? window.innerWidth * 0.0024 : 1.2;

        const planeGeometry = new THREE.PlaneGeometry(34, 8.5);

        for (let i = 0; i < PARTICLE_COUNT; i++) {
            // Начальный хаотичный разброс (взрывной старт)
            const startRadius = 400;
            const theta = Math.random() * Math.PI * 2;
            const phi = Math.acos((Math.random() * 2) - 1);
            const startX = startRadius * Math.sin(phi) * Math.cos(theta);
            const startY = startRadius * Math.sin(phi) * Math.sin(theta);
            const startZ = startRadius * Math.cos(phi);

            const cakeData = getCakePoint(i, PARTICLE_COUNT, currentScale);

            const material = new THREE.MeshBasicMaterial({
                map: texture,
                transparent: true,
                blending: THREE.AdditiveBlending,
                depthWrite: false,
                side: THREE.DoubleSide
            });
            
            // Раскраска: Торт - кислотно-зеленый/бирюзовый. Свечи - ядовито-красные!
            if (cakeData.type === 'cake') {
                material.color.lerpColors(new THREE.Color(0x00ff66), new THREE.Color(0x00ffff), Math.random());
            } else {
                material.color.setHex(0xff0033); // Огненные свечи
            }

            const mesh = new THREE.Mesh(planeGeometry, material);
            mesh.position.set(startX, startY, startZ);

            // Считаем вектор взрыва для свечки (направление от центра наружу)
            let explodeDir = new THREE.Vector3(cakeData.pos.x, 0, cakeData.pos.z).normalize();
            explodeDir.y = Math.random() * 1.5 + 0.5; // Свечи полетят вверх и в стороны

            mesh.userData = {
                targetPos: cakeData.pos.clone(),
                startPos: new THREE.Vector3(startX, startY, startZ),
                type: cakeData.type,
                explodeVector: explodeDir,
                explodeSpeed: Math.random() * 300 + 200,
                rotSpeed: (Math.random() - 0.5) * 5
            };

            particlesGroup.add(mesh);
        }

        window.addEventListener('resize', onWindowResize, false);
    }

    function onWindowResize() {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
        composer.setSize(window.innerWidth, window.innerHeight);
    }

    function animate() {
        requestAnimationFrame(animate);

        const elapsed = (Date.now() - startTime) / 1000;
        const delta = 0.016;

        // Переключение на взрыв свечей через 5 секунд после старта
        if (state.phase === 'assemble_cake' && elapsed > 5) {
            state.phase = 'explode_candles';
            state.timeInPhase = 0;
        }
        state.timeInPhase += delta;

        particlesGroup.children.forEach((mesh) => {
            const data = mesh.userData;
            const p = mesh.position;

            if (state.phase === 'assemble_cake') {
                // Из хаоса плавно собираем торт
                let speed = Math.min(elapsed / 3.5, 1) * 0.07;
                p.lerp(data.targetPos, speed);
                mesh.rotation.set(0, 0, 0);
                mesh.lookAt(camera.position);
            } 
            else if (state.phase === 'explode_candles') {
                if (data.type === 'candle') {
                    // ЭФФЕКТ ВЗРЫВА: Свечи разлетаются по баллистической траектории
                    const t = state.timeInPhase;
                    const moveVector = data.explodeVector.clone().multiplyScalar(data.explodeSpeed * t);
                    
                    // Добавляем гравитацию, чтобы буквы красиво падали вниз после взрыва
                    moveVector.y -= 180 * t * t; 
                    
                    p.copy(data.targetPos).add(moveVector);
                    
                    // В полете буквы свечей безумно крутятся
                    mesh.rotation.x += data.rotSpeed * 0.02;
                    mesh.rotation.y += data.rotSpeed * 0.03;
                } else {
                    // Сам торт остается на месте, слегка пульсируя от взрывной волны
                    const pulse = 1 + Math.sin(state.timeInPhase * 4) * 0.02;
                    p.copy(data.targetPos).multiplyScalar(pulse);
                    mesh.rotation.set(0, 0, 0);
                    mesh.lookAt(camera.position);
                }
            }
        });

        // Торт плавно крутится на праздничном столе, чтобы был виден весь 3D объем
        if (state.phase === 'assemble_cake') {
            particlesGroup.rotation.y = elapsed * 0.25;
        } else {
            // После взрыва крутится чуть быстрее под басы
            particlesGroup.rotation.y = 5 * 0.25 + state.timeInPhase * 0.5;
        }

        composer.render();
    }

    window.onload = () => {
        init();
        animate();
    };
</script>

</body>
</html>
